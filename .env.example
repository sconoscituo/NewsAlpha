# Gemini AI API 키 (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_key

# 데이터베이스 URL (SQLite 기본, 운영 시 PostgreSQL 권장)
DATABASE_URL=sqlite+aiosqlite:///./newsalpha.db

# JWT 시크릿 키 (openssl rand -hex 32 로 생성)
SECRET_KEY=your_secret

# 텔레그램 봇 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_token

# 디버그 모드
DEBUG=True

# 뉴스 수집 주기 (분 단위, 기본 30분)
COLLECT_INTERVAL_MINUTES=30

# 무료 사용자 일일 분석 한도
FREE_DAILY_LIMIT=10

# JWT 토큰 만료 시간 (분)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
